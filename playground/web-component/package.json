{
  "name": "@zeus-playground/web-components",
  "version": "0.0.1",
  "description": "Zeus Web Components Demo - Component Library",
  "type": "module",
  "main": "./dist/web-components.cjs",
  "module": "./dist/web-components.mjs",
  "types": "./dist/web-components.d.ts",
  "exports": {
    ".": {
      "import": "./dist/web-components.mjs",
      "require": "./dist/web-components.cjs",
      "types": "./dist/web-components.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rolldown -c",
    "dev": "rolldown -c -w",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@zeus-js/core": "workspace:*",
    "@zeus-js/web-components": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-replace": "^6.0.3",
    "@types/node": "^25.5.2",
    "rolldown": "1.0.0-rc.13",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "zeus",
    "web-components",
    "custom-elements"
  ],
  "author": "baicie",
  "license": "MIT"
}
