{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@zeus-js/core": ["../../packages/zeus/src/index.ts"],
      "@zeus-js/web-components": ["../../packages/web-components/src/index.ts"],
      "@zeus-js/signal": ["../../packages/signal/src/index.ts"],
      "@zeus-js/shared": ["../../packages/shared/src/index.ts"],
      "@zeus-js/runtime-core": ["../../packages/runtime-core/src/index.ts"],
      "@zeus-js/runtime-dom": ["../../packages/runtime-dom/src/index.ts"]
    },
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationDir": "./dist",
    "emitDeclarationOnly": false,
    "jsx": "preserve",
    "jsxImportSource": "@zeus-js/core",
    "types": ["../../packages/global.d.ts"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
