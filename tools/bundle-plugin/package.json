{
  "name": "@zeus-js/build-tools",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    "./vite": {
      "import": "./dist/esm/vite.mjs",
      "require": "./dist/cjs/vite.cjs",
      "types": "./dist/esm/vite.d.mts"
    },
    "./webpack": {
      "import": "./dist/esm/webpack.mjs",
      "require": "./dist/cjs/webpack.cjs",
      "types": "./dist/esm/webpack.d.mts"
    },
    "./rspack": {
      "import": "./dist/esm/rspack.mjs",
      "require": "./dist/cjs/rspack.cjs",
      "types": "./dist/esm/rspack.d.mts"
    },
    "./rollup": {
      "import": "./dist/esm/rollup.mjs",
      "require": "./dist/cjs/rollup.cjs",
      "types": "./dist/esm/rollup.d.mts"
    },
    "./rolldown": {
      "import": "./dist/esm/rolldown.mjs",
      "require": "./dist/cjs/rolldown.cjs",
      "types": "./dist/esm/rolldown.d.mts"
    },
    "./esbuild": {
      "import": "./dist/esm/esbuild.mjs",
      "require": "./dist/cjs/esbuild.cjs",
      "types": "./dist/esm/esbuild.d.mts"
    },
    "./turbopack": {
      "import": "./dist/esm/turbopack.mjs",
      "require": "./dist/cjs/turbopack.cjs",
      "types": "./dist/esm/turbopack.d.mts"
    },
    "./bun": {
      "import": "./dist/esm/bun.mjs",
      "require": "./dist/cjs/bun.cjs",
      "types": "./dist/esm/bun.d.mts"
    }
  },
  "scripts": {
    "build": "rolldown -c rolldown.config.ts",
    "dev": "rolldown -c rolldown.config.ts --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": "^18.0.0 || >=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baicie/zeus.git",
    "directory": "tools/build-tools"
  },
  "bugs": {
    "url": "https://github.com/baicie/zeus/issues"
  },
  "homepage": "https://github.com/baicie/zeus/tree/main/tools/build-tools#readme",
  "optionalDependencies": {
    "@rspack/core": "^1.7.7",
    "esbuild": "^0.27.3",
    "next": "^16.1.6",
    "rolldown": "^1.0.0",
    "rollup": "^4.59.0",
    "vite": "^7.3.1",
    "webpack": "^5.105.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/types": "catalog:",
    "@types/babel__core": "^7.20.5",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.3",
    "bun": "^1.3.10",
    "rolldown": "^1.0.0-rc.6",
    "rolldown-plugin-dts": "^0.22.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@zeus-js/compiler-core": "workspace:*"
  }
}
