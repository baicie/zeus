{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "strict": false,
    "noUnusedLocals": false,
    "jsx": "react-jsx",
    "jsxImportSource": "@zeus-js/zeus",
    "skipLibCheck": true,
    "noImplicitAny": false,
    "noEmit": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src",
    "../../packages/global.d.ts",
    "../../packages/core/zeus/src/jsx.d.ts"
  ]
}
