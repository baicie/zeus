{
  "name": "@zeus-js/vite-plugin",
  "version": "0.0.2",
  "type": "module",
  "description": "Vite plugin for Zeus",
  "main": "index.cjs",
  "module": "dist/vite-plugin.esm-bundler.js",
  "types": "dist/vite-plugin.d.ts",
  "files": [
    "index.cjs",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite-plugin.esm-bundler.js",
      "require": {
        "types": "./dist/vite-plugin.d.ts",
        "default": "./dist/vite-plugin.cjs.js"
      },
      "default": "./dist/vite-plugin.esm-bundler.js"
    }
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baicie/zeus.git",
    "directory": "packages/devtools/vite-plugin"
  },
  "buildOptions": {
    "name": "ZeusVitePlugin",
    "formats": [
      "esm-bundler",
      "cjs"
    ]
  },
  "keywords": [
    "zeus",
    "vite",
    "jsx"
  ],
  "author": "Baicie",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/baicie/zeus/issues"
  },
  "homepage": "https://github.com/baicie/zeus/tree/main/packages/devtools/vite-plugin#readme",
  "dependencies": {
    "@babel/core": "catalog:",
    "@zeus-js/compiler": "workspace:*"
  },
  "peerDependencies": {
    "vite": "catalog:"
  },
  "devDependencies": {
    "@types/babel__core": "catalog:"
  }
}
