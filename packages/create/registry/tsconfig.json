{
  "compilerOptions": {
    "target": "es2017",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "lib": ["es2016", "dom"],
    "types": ["node"],
    "outDir": "dist",
    "declaration": true,
    "noEmit": false
  },
  "include": ["src"]
}
