{
  "name": "zeus-ui",
  "version": "0.0.1",
  "description": "Add customizable Zeus UI components to your project.",
  "type": "module",
  "bin": {
    "zeus-ui": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --no-dts --clean --platform node --target node18",
    "dev": "tsup src/index.ts --format esm --no-dts --watch --platform node --target node18",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zeus-ui/registry": "workspace:*",
    "commander": "^15.0.0",
    "prompts": "^2.4.2",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
