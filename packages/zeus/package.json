{
  "name": "zeus-js",
  "version": "0.1.0-alpha.1",
  "description": "The progressive JavaScript framework for building modern web applications.",
  "main": "index.js",
  "module": "dist/zeus.runtime.esm-bundler.js",
  "types": "dist/zeus.d.ts",
  "unpkg": "dist/zeus.global.js",
  "jsdelivr": "dist/zeus.global.js",
  "files": [
    "index.js",
    "index.mjs",
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/zeus.d.mts",
        "node": "./index.mjs",
        "default": "./dist/zeus.runtime.esm-bundler.js"
      },
      "require": {
        "types": "./dist/zeus.d.ts",
        "node": {
          "production": "./dist/zeus.cjs.prod.js",
          "development": "./dist/zeus.cjs.js",
          "default": "./index.js"
        },
        "default": "./index.js"
      }
    },
    "./jsx-runtime": {
      "types": "./jsx-runtime/index.d.ts",
      "import": "./jsx-runtime/index.mjs",
      "require": "./jsx-runtime/index.js"
    },
    "./jsx-dev-runtime": {
      "types": "./jsx-runtime/index.d.ts",
      "import": "./jsx-runtime/index.mjs",
      "require": "./jsx-runtime/index.js"
    },
    "./jsx": "./jsx.d.ts",
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "buildOptions": {
    "name": "ZeusJs",
    "formats": [
      "esm-bundler",
      "esm-bundler-runtime",
      "cjs",
      "global",
      "global-runtime",
      "esm-browser",
      "esm-browser-runtime"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baicie/zeus.git"
  },
  "keywords": [
    "zeus"
  ],
  "author": "baicie",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/baicie/zeus/issues"
  },
  "homepage": "https://github.com/baicie/zeus/tree/main/packages/zeus#readme",
  "dependencies": {
    "@zeus-js/compiler": "workspace:*",
    "@zeus-js/runtime": "workspace:*",
    "@zeus-js/wc": "workspace:*"
  },
  "peerDependencies": {
    "typescript": "*"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
