{
  "name": "@zeus/compiler",
  "version": "1.0.0",
  "description": "Zeus JSX Compiler - 编译 JSX 到 Zeus 框架，无虚拟 DOM",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./babel-plugin": {
      "import": "./dist/babel-plugin.mjs",
      "require": "./dist/babel-plugin.js",
      "types": "./dist/babel-plugin.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node test.js",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "jsx",
    "compiler",
    "zeus",
    "babel-plugin",
    "virtual-dom",
    "dom"
  ],
  "author": "Zeus Team",
  "license": "MIT",
  "packageManager": "pnpm@10.15.0",
  "dependencies": {
    "@babel/core": "^7.28.3",
    "@babel/parser": "^7.28.3",
    "@babel/traverse": "^7.28.3",
    "@babel/types": "^7.28.3"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/babel__traverse": "^7.20.5",
    "tsup": "^8.0.2",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@babel/core": "^7.0.0"
  }
}
