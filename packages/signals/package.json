{
  "name": "@zeus-js/signals",
  "version": "0.0.0",
  "main": "index.js",
  "module": "dist/signals.esm-bundler.js",
  "types": "dist/signals.d.ts",
  "files": [
    "index.js",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/signals.d.ts",
      "node": {
        "production": "./dist/signals.cjs.prod.js",
        "development": "./dist/signals.cjs.js",
        "default": "./index.js"
      },
      "module": "./dist/signals.esm-bundler.js",
      "import": "./dist/signals.esm-bundler.js",
      "require": "./index.js"
    },
    "./*": "./*"
  },
  "sideEffects": false,
  "buildOptions": {
    "name": "ZeusSignals",
    "formats": [
      "esm-bundler",
      "esm-browser",
      "cjs",
      "global"
    ]
  },
  "devDependencies": {
    "jest-extended": "^7.0.0"
  }
}
