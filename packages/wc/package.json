{
  "name": "@zeus-js/wc",
  "version": "0.0.0",
  "main": "index.js",
  "module": "dist/wc.esm.js",
  "types": "dist/wc.d.ts",
  "files": [
    "index.js",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/wc.d.ts",
      "node": {
        "production": "./dist/wc.cjs.prod.js",
        "development": "./dist/wc.cjs.js",
        "default": "./index.js"
      },
      "module": "./dist/wc.esm.js",
      "import": "./dist/wc.esm.js",
      "require": "./index.js"
    },
    "./*": "./*"
  },
  "sideEffects": false,
  "buildOptions": {
    "name": "ZeusWc",
    "formats": [
      "esm-bundler",
      "esm-browser",
      "cjs",
      "global"
    ]
  },
  "dependencies": {
    "@zeus-js/runtime": "workspace:*"
  }
}
