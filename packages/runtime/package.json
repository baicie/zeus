{
  "name": "@zeus-js/runtime",
  "version": "0.0.0",
  "main": "index.js",
  "module": "dist/runtime.esm.js",
  "types": "dist/runtime.d.ts",
  "files": [
    "index.js",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/runtime.d.ts",
      "node": {
        "production": "./dist/runtime.cjs.prod.js",
        "development": "./dist/runtime.cjs.js",
        "default": "./index.js"
      },
      "module": "./dist/runtime.esm.js",
      "import": "./dist/runtime.esm.js",
      "require": "./index.js"
    },
    "./*": "./*"
  },
  "sideEffects": false,
  "buildOptions": {
    "formats": [
      "esm",
      "cjs"
    ]
  },
  "dependencies": {
    "alien-signals": "^3.0.0",
    "csstype": "^3.1.3"
  }
}
