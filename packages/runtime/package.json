{
  "name": "@zeus-js/runtime",
  "version": "0.0.0",
  "main": "index.js",
  "module": "dist/runtime.esm-bundler.js",
  "types": "dist/runtime.d.ts",
  "files": [
    "index.js",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/runtime.d.ts",
      "node": {
        "production": "./dist/runtime.cjs.prod.js",
        "development": "./dist/runtime.cjs.js",
        "default": "./index.js"
      },
      "module": "./dist/runtime.esm-bundler.js",
      "import": "./dist/runtime.esm-bundler.js",
      "require": "./index.js"
    },
    "./*": "./*"
  },
  "sideEffects": false,
  "buildOptions": {
    "name": "ZeusRuntime",
    "formats": [
      "esm-bundler",
      "esm-browser",
      "cjs",
      "global"
    ]
  },
  "dependencies": {
    "@zeus-js/signals": "workspace:*",
    "csstype": "^3.2.3"
  }
}
