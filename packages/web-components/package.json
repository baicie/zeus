{
  "name": "@zeus-js/web-components",
  "version": "0.0.1",
  "type": "commonjs",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "rollup -c ../../rollup.config.js --watch",
    "build": "rollup -c ../../rollup.config.js",
    "test": "vitest",
    "test:run": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "node": "^18.0.0 || >=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baicie/zeus.git",
    "directory": "packages/web-components"
  },
  "bugs": {
    "url": "https://github.com/baicie/zeus/issues"
  },
  "homepage": "https://github.com/baicie/zeus/tree/main/packages/web-components#readme",
  "dependencies": {
    "@zeus-js/runtime-core": "workspace:*",
    "@zeus-js/runtime-dom": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
