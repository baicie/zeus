{
  "name": "@zeus-js/component-analyzer",
  "type": "module",
  "version": "0.1.0-beta.6",
  "description": "Zeus component analyzer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baicie/zeus.git",
    "directory": "packages/web-c/component-analyzer"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/component-analyzer.d.ts",
      "module": "./dist/component-analyzer.esm-bundler.js",
      "import": "./dist/component-analyzer.esm-bundler.js",
      "require": "./index.js",
      "node": {
        "production": "./dist/component-analyzer.cjs.prod.js",
        "development": "./dist/component-analyzer.cjs.js",
        "default": "./index.js"
      }
    }
  },
  "files": [
    "index.js",
    "dist"
  ],
  "dependencies": {
    "@babel/parser": "catalog:",
    "@babel/types": "catalog:",
    "fast-glob": "^3.3.3"
  },
  "author": "Baicie",
  "buildOptions": {
    "name": "ZeusComponentAnalyzer",
    "formats": [
      "esm-bundler",
      "cjs"
    ]
  },
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "keywords": [
    "zeus",
    "web-components",
    "component-analyzer"
  ],
  "main": "index.js",
  "module": "dist/component-analyzer.esm-bundler.js",
  "types": "dist/component-analyzer.d.ts"
}
