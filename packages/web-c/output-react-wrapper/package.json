{
  "name": "@zeus-js/output-react-wrapper",
  "type": "module",
  "version": "0.1.0-beta.6",
  "description": "Zeus React wrapper output plugin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baicie/zeus.git",
    "directory": "packages/web-c/output-react-wrapper"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/output-react-wrapper.d.ts",
      "module": "./dist/output-react-wrapper.esm-bundler.js",
      "import": "./dist/output-react-wrapper.esm-bundler.js",
      "require": "./index.js",
      "node": {
        "production": "./dist/output-react-wrapper.cjs.prod.js",
        "development": "./dist/output-react-wrapper.cjs.js",
        "default": "./index.js"
      }
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "require": "./dist/runtime/index.cjs.js"
    }
  },
  "files": [
    "index.js",
    "dist"
  ],
  "peerDependencies": {
    "@types/react": "17 || 18 || 19",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@lit/react": "^1.0.8",
    "@zeus-js/bundler-plugin": "workspace:*",
    "@zeus-js/component-analyzer": "workspace:*",
    "@zeus-js/component-dts": "workspace:*"
  },
  "author": "Baicie",
  "buildOptions": {
    "name": "ZeusOutputReactWrapper",
    "formats": [
      "esm-bundler",
      "cjs"
    ],
    "additionalEntries": [
      {
        "entry": "runtime/index.ts",
        "output": "dist/runtime/index.js"
      }
    ]
  },
  "keywords": [
    "zeus",
    "react",
    "web-components"
  ],
  "main": "index.js",
  "module": "dist/output-react-wrapper.esm-bundler.js",
  "types": "dist/output-react-wrapper.d.ts"
}
