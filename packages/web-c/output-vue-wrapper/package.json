{
  "name": "@zeus-js/output-vue-wrapper",
  "type": "module",
  "version": "0.1.0-beta.6",
  "description": "Zeus Vue wrapper output plugin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baicie/zeus.git",
    "directory": "packages/web-c/output-vue-wrapper"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/output-vue-wrapper.d.ts",
      "module": "./dist/output-vue-wrapper.esm-bundler.js",
      "import": "./dist/output-vue-wrapper.esm-bundler.js",
      "require": "./index.js",
      "node": {
        "production": "./dist/output-vue-wrapper.cjs.prod.js",
        "development": "./dist/output-vue-wrapper.cjs.js",
        "default": "./index.js"
      }
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "require": "./dist/runtime/index.cjs.js"
    }
  },
  "files": [
    "index.js",
    "dist"
  ],
  "peerDependencies": {
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@zeus-js/bundler-plugin": "workspace:*",
    "@zeus-js/component-analyzer": "workspace:*",
    "@zeus-js/component-dts": "workspace:*"
  },
  "author": "Baicie",
  "buildOptions": {
    "name": "ZeusOutputVueWrapper",
    "formats": [
      "esm-bundler",
      "cjs"
    ],
    "additionalEntries": [
      {
        "entry": "runtime/index.ts",
        "output": "dist/runtime/index.js"
      }
    ]
  },
  "keywords": [
    "zeus",
    "vue",
    "web-components"
  ],
  "main": "index.js",
  "module": "dist/output-vue-wrapper.esm-bundler.js",
  "types": "dist/output-vue-wrapper.d.ts"
}
