{
  "name": "@zeus-js/output-icons",
  "type": "module",
  "version": "0.1.0-beta.6",
  "description": "No-runtime icon output plugin for Zeus component compiler host",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baicie/zeus.git",
    "directory": "packages/web-c/output-icons"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/output-icons.d.ts",
      "module": "./dist/output-icons.esm-bundler.js",
      "import": "./dist/output-icons.esm-bundler.js",
      "require": "./index.js",
      "node": {
        "production": "./dist/output-icons.cjs.prod.js",
        "development": "./dist/output-icons.cjs.js",
        "default": "./index.js"
      }
    }
  },
  "files": [
    "index.js",
    "dist"
  ],
  "peerDependencies": {
    "react": ">=18 || >=19",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@zeus-js/bundler-plugin": "workspace:*"
  },
  "author": "Baicie",
  "buildOptions": {
    "name": "ZeusOutputIcons",
    "formats": [
      "esm-bundler",
      "cjs"
    ]
  },
  "keywords": [
    "zeus",
    "icons",
    "web-components",
    "react",
    "vue"
  ],
  "main": "index.js",
  "module": "dist/output-icons.esm-bundler.js",
  "types": "dist/output-icons.d.ts"
}
