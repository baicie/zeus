{
  "name": "@zeus-js/output-css",
  "type": "module",
  "version": "0.1.0-beta.6",
  "description": "Zeus CSS asset output plugin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baicie/zeus.git",
    "directory": "packages/web-c/output-css"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/output-css.d.ts",
      "module": "./dist/output-css.esm-bundler.js",
      "import": "./dist/output-css.esm-bundler.js",
      "require": "./index.js",
      "node": {
        "production": "./dist/output-css.cjs.prod.js",
        "development": "./dist/output-css.cjs.js",
        "default": "./index.js"
      }
    }
  },
  "files": [
    "index.js",
    "dist"
  ],
  "peerDependencies": {
    "lightningcss": "^1.29.0",
    "postcss": "*",
    "postcss-load-config": "*",
    "rollup": "^4.0.0",
    "sass": "*",
    "less": "*"
  },
  "peerDependenciesMeta": {
    "lightningcss": {
      "optional": true
    },
    "postcss": {
      "optional": true
    },
    "postcss-load-config": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "sass": {
      "optional": true
    },
    "less": {
      "optional": true
    }
  },
  "author": "Baicie",
  "buildOptions": {
    "name": "ZeusOutputCSS",
    "formats": [
      "esm-bundler",
      "cjs"
    ]
  },
  "keywords": [
    "zeus",
    "css"
  ],
  "main": "index.js",
  "module": "dist/output-css.esm-bundler.js",
  "types": "dist/output-css.d.ts"
}
