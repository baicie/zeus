{
  "name": "@zeus-js/compiler",
  "type": "module",
  "version": "0.1.0-beta.6",
  "description": "@zeus-js/compiler",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baicie/zeus.git",
    "directory": "packages/core/compiler"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/compiler.d.ts",
      "module": "./dist/compiler.esm-bundler.js",
      "import": "./dist/compiler.esm-bundler.js",
      "require": "./index.js",
      "node": {
        "production": "./dist/compiler.cjs.prod.js",
        "development": "./dist/compiler.cjs.js",
        "default": "./index.js"
      }
    }
  },
  "files": [
    "index.js",
    "dist"
  ],
  "peerDependencies": {
    "@babel/core": "catalog:"
  },
  "dependencies": {
    "@babel/helper-plugin-utils": "^8.0.1",
    "@babel/types": "catalog:",
    "@baicie/logger": "^0.2.0",
    "@zeus-js/shared": "workspace:*"
  },
  "devDependencies": {
    "@babel/core": "catalog:"
  },
  "author": "Baicie",
  "bugs": {
    "url": "https://github.com/baicie/zeus/issues"
  },
  "buildOptions": {
    "name": "ZeusCompiler",
    "formats": [
      "esm-bundler",
      "esm-browser",
      "cjs",
      "global"
    ]
  },
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "homepage": "https://github.com/baicie/zeus/tree/main/packages/core/compiler#readme",
  "jsdelivr": "dist/compiler.global.js",
  "keywords": [
    "zeus"
  ],
  "main": "index.js",
  "module": "dist/compiler.esm-bundler.js",
  "types": "dist/compiler.d.ts",
  "unpkg": "dist/compiler.global.js"
}
