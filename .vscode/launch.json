{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Vitest Debug",
      "program": "${workspaceRoot}/node_modules/vitest/vitest.mjs",
      "args": ["run", "${relativeFile}"],
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Compiler Debug",
      "cwd": "${workspaceRoot}/examples/compiler",
      "program": "${workspaceRoot}/examples/compiler/src/index.js"
    }
  ]
}
