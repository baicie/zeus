{
  "name": "root",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "node scripts/build.js",
    "build-dts": "tsc -p tsconfig.build.json --noCheck && rollup -c rollup.dts.config.js",
    "clean": "rimraf --glob packages/*/dist temp .eslintcache",
    "size": "run-s \"size-*\" && node scripts/usage-size.js",
    "size-global": "node scripts/build.js zeus -f global -p --size",
    "size-esm-runtime": "node scripts/build.js zeus -f esm-bundler-runtime",
    "size-esm": "node scripts/build.js runtime signals -f esm-bundler",
    "check": "tsc --incremental --noEmit",
    "lint": "eslint --cache .",
    "format": "prettier --write --cache .",
    "format-check": "prettier --check --cache .",
    "test": "vitest",
    "test-unit": "vitest --project unit*",
    "test-e2e": "node scripts/build.js zeus -f global -d && vitest --project e2e",
    "test-dts": "run-s build-dts test-dts-only",
    "test-dts-only": "echo 'test-dts-only'",
    "test-coverage": "vitest run --project unit* --coverage",
    "benchmark": "vitest run benchmarks/",
    "benchmark:watch": "vitest watch benchmarks/",
    "benchmark:report": "node scripts/generate-benchmark-report.js",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm check",
    "commit-msg": "node scripts/verify-commit.js"
  },
  "lint-staged": {
    "*.{js,json}": [
      "prettier --write"
    ],
    "*.ts?(x)": [
      "eslint --fix",
      "prettier --parser=typescript --write"
    ]
  },
  "engines": {
    "node": ">=18.12.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.28.5",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@swc/core": "^1.15.1",
    "@types/node": "^24.9.1",
    "@vitest/coverage-v8": "^4.0.8",
    "@vitest/eslint-plugin": "^1.4.2",
    "esbuild": "^0.27.0",
    "esbuild-plugin-polyfill-node": "^0.3.0",
    "eslint": "^9.39.1",
    "eslint-plugin-import-x": "^4.16.1",
    "jsdom": "^27.2.0",
    "lint-staged": "^16.2.6",
    "magic-string": "^0.30.21",
    "npm-run-all": "^4.1.5",
    "picocolors": "^1.1.1",
    "prettier": "^3.6.2",
    "pretty-bytes": "^7.1.0",
    "puppeteer": "^24.29.1",
    "rimraf": "^6.1.0",
    "rolldown": "1.0.0-beta.50",
    "rollup": "^4.53.2",
    "rollup-plugin-dts": "^6.2.3",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "unbuild": "^3.6.1",
    "vitest": "^4.0.8"
  }
}
