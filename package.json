{
  "name": "root",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/build.ts --watch",
    "build": "tsx scripts/build.ts",
    "build-dts": "tsc -p tsconfig.build.json --noCheck && rolldown -c ./scripts/rolldown.dts.config.ts",
    "clean": "rimraf --glob packages/*/dist temp .eslintcache",
    "check": "tsc --incremental --noEmit",
    "lint": "eslint --cache .",
    "lint-fix": "eslint --fix .",
    "format": "prettier --write --cache .",
    "format-check": "prettier --check --cache .",
    "test": "vitest",
    "test-unit": "vitest --project unit*",
    "test-coverage": "vitest run --project unit* --coverage",
    "test:benchs": "vitest run packages/signal/src/__tests__/benchs/",
    "playground": "pnpm -F @zeus-js/playground dev",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm check",
    "commit-msg": "node -e \"import('@baicie/scripts').then(m => m.verifyCommit())\""
  },
  "lint-staged": {
    "*.{js,json}": [
      "prettier --write"
    ],
    "*.ts?(x)": [
      "eslint --fix",
      "prettier --parser=typescript --write"
    ]
  },
  "engines": {
    "node": ">=18.12.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/parser": "^7.29.3",
    "@babel/types": "^7.29.0",
    "@baicie/scripts": "^0.1.2",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260507.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.17",
    "cross-env": "^10.1.0",
    "esbuild-plugin-polyfill-node": "^0.3.0",
    "eslint": "^10.3.0",
    "eslint-plugin-import-x": "^4.16.2",
    "jest-extended": "^7.0.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.3",
    "magic-string": "^0.30.21",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.3",
    "pretty-bytes": "^7.1.0",
    "puppeteer": "^24.43.0",
    "rimraf": "^6.1.3",
    "rolldown": "1.0.0",
    "rolldown-plugin-dts": "^0.25.0",
    "rollup": "^4.60.3",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
