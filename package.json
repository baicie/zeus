{
  "name": "root",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/build.ts --watch",
    "build": "tsx scripts/build.ts",
    "build-all": "pnpm build-pkg && pnpm build-napi && pnpm build-addons",
    "build-pkg": "pnpm build -t",
    "build-napi": "pnpm --filter @zeus-js/compiler-core build-native:debug && pnpm --filter @zeus-js/compiler-browser build:debug",
    "build-addons": "pnpm --filter \"./addons/**\" --parallel build",
    "build-dts": "tsc -p tsconfig.build.json --noCheck && rolldown -c ./scripts/rolldown.dts.config.ts",
    "clean": "rimraf --glob packages/*/dist addons/*/dist temp .eslintcache",
    "size": "run-s \"size-*\" && node scripts/usage-size.js",
    "size-global": "tsx scripts/build.ts zeus -f global -p --size",
    "size-esm-runtime": "tsx scripts/build.ts zeus -f esm-bundler-runtime",
    "size-esm": "tsx scripts/build.ts runtime signals -f esm-bundler",
    "check": "tsc --incremental --noEmit",
    "lint": "eslint --cache .",
    "lint-fix": "eslint --fix .",
    "format": "prettier --write --cache .",
    "format-check": "prettier --check --cache .",
    "test": "vitest",
    "test-unit": "vitest --project unit*",
    "test-e2e": "tsx scripts/build.ts zeus -f global -d && vitest --project e2e",
    "test-hydration-browser-matrix": "cross-env HYDRATION_BROWSER_MATRIX=1 vitest --config vitest.config.ts --project unit-server-renderer \"packages/server-renderer/__tests__/hydration-events.browser.test.ts\"",
    "test-hydration-browser-chromium": "cross-env HYDRATION_BROWSER_MATRIX=1 HYDRATION_BROWSERS=chromium vitest --config vitest.config.ts --project unit-server-renderer \"packages/server-renderer/__tests__/hydration-events.browser.test.ts\"",
    "test-dts": "run-s build-dts test-dts-only",
    "test-dts-only": "echo 'test-dts-only'",
    "test-coverage": "vitest run --project unit* --coverage",
    "benchmark": "vitest run benchmarks/",
    "benchmark:watch": "vitest watch benchmarks/",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm check",
    "commit-msg": "node -e \"import('@baicie/scripts').then(m => m.verifyCommit())\""
  },
  "lint-staged": {
    "*.{js,json}": [
      "prettier --write"
    ],
    "*.ts?(x)": [
      "eslint --fix",
      "prettier --parser=typescript --write"
    ]
  },
  "engines": {
    "node": ">=18.12.0"
  },
  "devDependencies": {
    "@babel/parser": "catalog:",
    "@babel/types": "catalog:",
    "@baicie/scripts": "^0.1.2",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@swc/core": "^1.15.24",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/eslint-plugin": "^1.6.14",
    "cross-env": "^10.1.0",
    "esbuild-plugin-polyfill-node": "^0.3.0",
    "eslint": "^10.2.0",
    "eslint-plugin-import-x": "^4.16.2",
    "fast-glob": "^3.3.3",
    "glob": "^13.0.6",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "magic-string": "^0.30.21",
    "npm-run-all": "^4.1.5",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.1",
    "pretty-bytes": "^7.1.0",
    "puppeteer": "^24.40.0",
    "rimraf": "^6.1.3",
    "rolldown": "1.0.0-rc.13",
    "rolldown-plugin-dts": "^0.23.2",
    "rollup": "^4.60.1",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  }
}
