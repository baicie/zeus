{
  "name": "root",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/build.ts --watch",
    "build": "tsx scripts/build.ts",
    "build-dts": "tsc -p tsconfig.build.json --noCheck && rollup -c ./scripts/rollup.dts.config.ts",
    "clean": "rimraf --glob packages/*/dist temp .eslintcache",
    "check": "tsc --incremental --noEmit",
    "lint": "eslint --cache .",
    "lint-fix": "eslint --fix .",
    "format": "prettier --write --cache .",
    "format-check": "prettier --check --cache .",
    "test": "vitest",
    "test-unit": "vitest --project 'unit*'",
    "test-coverage": "vitest run --project unit* --coverage",
    "test:benchs": "vitest bench --project bench",
    "size": "pnpm build && tsx scripts/size-report.ts",
    "docs:dev": "pnpm -C docs dev",
    "docs:build": "pnpm -C docs build",
    "docs:preview": "pnpm -C docs preview",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && pnpm build-dts && changeset publish",
    "create-zeus:build": "pnpm -F create-zeus build",
    "examples:check": "pnpm -r --filter './examples/**' check",
    "playground": "pnpm -F @zeus-js/playground dev",
    "playground:solidjs": "pnpm -F @zeus-js/playground-solidjs dev",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm check",
    "commit-msg": "node -e \"import('@baicie/scripts').then(m => m.verifyCommit())\""
  },
  "lint-staged": {
    "*.{js,json}": [
      "prettier --write"
    ],
    "*.ts?(x)": [
      "eslint --fix",
      "prettier --parser=typescript --write"
    ]
  },
  "engines": {
    "node": ">=18.12.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/parser": "^7.29.7",
    "@babel/preset-typescript": "catalog:",
    "@babel/types": "^7.29.7",
    "@baicie/plugin-dts": "^0.0.1",
    "@baicie/scripts": "^0.1.2",
    "@changesets/cli": "^2.31.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260526.1",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/eslint-plugin": "^1.6.18",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^10.4.0",
    "eslint-plugin-import-x": "^4.16.2",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "magic-string": "^0.30.21",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.3",
    "pretty-bytes": "^7.1.0",
    "puppeteer": "^25.1.0",
    "rimraf": "^6.1.3",
    "rolldown": "1.0.2",
    "rolldown-plugin-dts": "^0.25.1",
    "rollup": "^4.60.4",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "simple-git-hooks": "^2.13.1",
    "tslib": "^2.8.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
