{
  "include": ["src", "core", "adapters"],
  "exclude": ["**/*.spec.ts", "dist", "node_modules"],
  "compilerOptions": {
    "outDir": "dist",
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "resolveJsonModule": true
  }
}
