{
  "name": "@zeus-js/vite-plugin-zeus",
  "version": "0.0.1",
  "description": "Vite plugin for Zeus JSX (Babel compiler)",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.mts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "scripts": {
    "build": "rolldown -c rolldown.config.ts",
    "dev": "rolldown -c rolldown.config.ts --watch",
    "clean": "rimraf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baicie/zeus.git",
    "directory": "addons/vite-plugin-zeus"
  },
  "keywords": [
    "zeus",
    "vite-plugin"
  ],
  "peerDependencies": {
    "vite": "^6.0.0 || ^7.0.0"
  },
  "dependencies": {
    "@zeus-js/compiler": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "rolldown": "^1.0.0-rc.12",
    "rolldown-plugin-dts": "^0.23.2",
    "typescript": "^6.0.2",
    "vite": "catalog:"
  }
}
