{
  "name": "@zeus-js/babel-preset-zeus",
  "version": "0.0.1",
  "description": "Babel preset: TypeScript + Zeus JSX compiler",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.mts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "scripts": {
    "build": "rolldown -c rolldown.config.ts",
    "dev": "rolldown -c rolldown.config.ts --watch",
    "clean": "rimraf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baicie/zeus.git",
    "directory": "addons/babel-preset-zeus"
  },
  "keywords": [
    "zeus",
    "babel-preset"
  ],
  "dependencies": {
    "@babel/core": "catalog:",
    "@babel/preset-typescript": "catalog:",
    "@zeus-js/compiler": "workspace:*"
  },
  "devDependencies": {
    "@types/babel__core": "catalog:",
    "@types/node": "^25.5.2",
    "rolldown": "^1.0.0-rc.13",
    "rolldown-plugin-dts": "^0.23.2",
    "typescript": "^6.0.2"
  }
}
