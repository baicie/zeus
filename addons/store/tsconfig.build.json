{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@zeus-js/signal": ["../../packages/signal/src/index.ts"],
      "@zeus-js/shared": ["../../packages/shared/src/index.ts"],
      "@zeus-js/runtime-core": ["../../packages/runtime-core/src/index.ts"]
    }
  },
  "include": ["../../packages/global.d.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
