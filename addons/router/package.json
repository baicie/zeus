{
  "name": "@zeus-js/router",
  "version": "0.0.1",
  "description": "Official router for Zeus framework",
  "main": "index.js",
  "module": "dist/router.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "index.js",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "node": {
        "production": "./dist/router.cjs.prod.js",
        "development": "./dist/router.cjs.js",
        "default": "./index.js"
      },
      "module": "./dist/router.mjs",
      "import": "./dist/router.mjs",
      "require": "./index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "build": "rolldown -c rolldown.config.ts && tsc -p tsconfig.build.json",
    "dev": "rolldown -c rolldown.config.ts --watch",
    "clean": "rimraf dist"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baicie/zeus.git",
    "directory": "addons/router"
  },
  "keywords": [
    "zeus",
    "router"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/baicie/zeus/issues"
  },
  "homepage": "https://github.com/baicie/zeus/tree/main/addons/router#readme",
  "dependencies": {
    "@zeus-js/shared": "workspace:*",
    "@zeus-js/signal": "workspace:*"
  }
}
