{
  "compilerOptions": {
    "jsx": "preserve",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "isolatedDeclarations": true,
    "noUnusedLocals": true,
    "experimentalDecorators": true,
    "composite": true,
    "incremental": true,
    "types": ["vitest/globals", "node"],
    "paths": {
      "@zeus-js/*": ["./packages/*/src"]
    }
  },
  "include": [
    "packages/global.d.ts",
    "packages/*/src",
    "packages/*/__tests__",
    "scripts/*",
    "rollup.*.js"
  ],
  "exclude": ["**/dist", "**/node_modules", "**/temp"]
}
