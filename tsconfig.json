{
  "compilerOptions": {
    "outDir": "temp",
    "sourceMap": false,
    "target": "es2017",
    "newLine": "LF",
    "useDefineForClassFields": false,
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": false,
    "strict": true,
    "noUnusedLocals": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "removeComments": false,
    "jsx": "preserve",
    "lib": ["es2016", "dom"],
    "types": ["vitest/globals", "puppeteer", "node"],
    "rootDir": ".",
    "paths": {
      "*": ["./*"],
      "@zeus-js/*": [
        "./packages/core/*/src",
        "./packages/web-c/*/src",
        "./packages/devtools/*/src"
      ],
      "@zeus-ui/*": ["./packages/*/src", "./examples/headless/src"],
      "@zeus-ui/headless": ["./examples/headless/src"],
      "@zeus-ui/registry": ["./packages/create/registry/src"]
    },
    "composite": false
  },
  "include": [
    "packages/global.d.ts",
    "packages/core/*/src",
    "packages/core/*/__tests__",
    "packages/devtools/*/src",
    "packages/devtools/*/__tests__",
    "packages/web-c/*/src",
    "packages/web-c/*/__tests__",
    "examples/headless/src",
    "examples/headless/__tests__",
    "packages/create/registry/src",
    "packages/create/registry/__tests__",
    "create/*/src",
    "create/*/__tests__",
    "benchmarks/*/src",
    "benchmarks/*/vite.config.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["create/zeus-ui/src"]
}
